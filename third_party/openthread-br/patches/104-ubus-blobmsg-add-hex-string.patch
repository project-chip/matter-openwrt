--- a/src/openwrt/ubus/CMakeLists.txt
+++ b/src/openwrt/ubus/CMakeLists.txt
@@ -28,6 +28,7 @@
 
 add_library(otbr-ubus
     otubus.cpp
+    ubus_utils.cpp
 )
