 src/openwrt/ubus/otubus.hpp     |  9 ----
 src/openwrt/ubus/ubus_utils.cpp | 49 +++++++++++++++++++++
 src/openwrt/ubus/ubus_utils.hpp |  4 ++
 5 files changed, 72 insertions(+), 67 deletions(-)
 create mode 100644 src/openwrt/ubus/ubus_utils.cpp

diff --git a/src/openwrt/ubus/CMakeLists.txt b/src/openwrt/ubus/CMakeLists.txt
